{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noUnknownAtRules": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": [
			"**/*.js",
			"**/*.ts",
			"**/*.tsx",
			"**/*.jsx",
			"**/*.json",
			"**/*.css",
			"!!**/.claude",
			"!**/.next",
			"!**/node_modules",
			"!**/dist",
			"!**/out",
			"!**/.turbo"
		]
	}
}
